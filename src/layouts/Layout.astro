---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Mesa Budget Simulator", description = "Build and share your own City of Mesa FY 2025/26 budget." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#2a6ebb" />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}mesa-logo.png`} />
    <title>{title}</title>
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-mesa-blue focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to main content
    </a>
    <slot />
  </body>
</html>

<style is:global>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
